# Copy to .env for local development. Never commit a real .env.
# These defaults match docker-compose.yml.

# HTTP server
HTTP_ADDR=:8080
LOG_LEVEL=info

# Postgres connection — shared by the control-plane DB and all tenant DBs
# (they differ only by database name).
DB_HOST=localhost
DB_PORT=5432
DB_USER=opero
DB_PASSWORD=opero
DB_SSLMODE=disable

# Control-plane database name. Tenant DBs are provisioned per tenant (M1).
CONTROLPLANE_DB_NAME=opero_control

# Prefix for per-tenant logical database names (slug is appended, sanitized).
TENANT_DB_PREFIX=opero_tenant_

# Auth. JWT_SECRET is REQUIRED (no default) — use a long random value in prod.
JWT_SECRET=dev-only-change-me-to-a-long-random-string
JWT_ISSUER=opero
JWT_TTL=24h

# CORS: comma-separated browser origins allowed to call the API.
# Empty disables CORS. Origin matching is exact, so list both localhost and
# 127.0.0.1 — a browser treats them as different origins even on the same port.
# Vite's default dev server port is 5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Object storage (S3-compatible) for media uploads, e.g. check-in photos.
# Defaults match the MinIO service in docker-compose.yml.
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=opero
STORAGE_SECRET_KEY=opero-secret
STORAGE_BUCKET=opero-media
STORAGE_USE_SSL=false
# If set, returned URLs are "<STORAGE_PUBLIC_URL>/<bucket>/<key>" (object must
# be publicly readable). If empty, the API returns presigned GET URLs valid for
# STORAGE_PRESIGN_EXPIRY — the local/dev default.
STORAGE_PUBLIC_URL=
STORAGE_PRESIGN_EXPIRY=168h

# Demo tooling: the single tenant slug allowed to call POST /demo/seed-live-view.
# Empty (the default) disables demo seeding — leave empty in production.
DEMO_TENANT_SLUG=demo
